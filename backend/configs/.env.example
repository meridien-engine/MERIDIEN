# MERIDIEN - Environment Configuration Template
# Copy this file to .env and fill in your values
# cp .env.example .env

APP_NAME=MERIDIEN
APP_ENV=development
APP_PORT=8080
APP_DEBUG=false

# Database (Neon PostgreSQL or local)
# Neon connection string format:
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=require

# JWT
JWT_SECRET=
JWT_EXPIRATION_HOURS=24
